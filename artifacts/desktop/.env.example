# ─── LiveStorm AI Desktop — Environment ──────────────────────────────────────
#
# Copy to .env and fill in values for local development.

# URL of the LiveStorm AI web app to load in the desktop window.
# Dev:  http://localhost:5173   (or the Replit dev domain)
# Prod: https://your-deploy.replit.app
LIVESTORM_APP_URL=https://your-deploy.replit.app

# Optional: override the start URL in dev mode (set automatically by scripts/dev.js)
# ELECTRON_START_URL=http://localhost:5173
