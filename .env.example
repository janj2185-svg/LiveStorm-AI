# ─────────────────────────────────────────────────────────────────────────────
# LiveStorm AI — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── TikTok mode ───────────────────────────────────────────────────────────────
# "real"  → connects to actual TikTok LIVE (requires tiktok-live-connector)
# "demo"  → built-in simulator, no real TikTok needed (safe for staging)
TIKTOK_MODE=real

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Get from: Replit → Tools → Database  OR  Supabase / Neon / Railway / etc.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Clerk authentication ───────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Stripe (optional — leave blank if not using billing) ──────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
