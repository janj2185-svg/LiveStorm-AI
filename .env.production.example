# ══════════════════════════════════════════════════════════════════════════════
# LiveStorm AI — Production Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in all values before deploying.
# NEVER commit the actual .env file to git.
#
# Last updated: 2025-06-20
# ══════════════════════════════════════════════════════════════════════════════

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Database (PostgreSQL 16) ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://livestorm:STRONG_PASSWORD@localhost:5432/livestormdb

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_CLERK_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# On VPS: use OpenAI directly (not Replit proxy)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── TikTok LIVE ───────────────────────────────────────────────────────────────
# TIKTOK_MODE: "real" = live TikTok connection, "demo" = simulator
TIKTOK_MODE=real

# LIVE_PROVIDER: "tiktools" (recommended) or "euler"
LIVE_PROVIDER=tiktools

# tik.tools API key — get from: https://tik.tools (personal key, not demo)
TIKTOOL_API_KEY=your_tiktools_api_key_here

# ── Object Storage ────────────────────────────────────────────────────────────
# On Replit: uses Replit Object Storage (auto-configured)
# On VPS: use local filesystem paths or MinIO (see DEPLOYMENT GUIDE)
PRIVATE_OBJECT_DIR=/data/private
PUBLIC_OBJECT_SEARCH_PATHS=/data/public

# Signing API for secure file URLs (Replit-specific — see notes in guide)
SIGN_API_KEY=your_sign_api_key
SIGN_API_URL=https://your-sign-api.com

# ── Stripe (optional — only if monetization enabled) ─────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Google OAuth (optional — for "Continue with Google" in Clerk) ─────────────
# Configure in Google Cloud Console → Credentials
GOOGLE_CLIENT_ID=XXXXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXXX

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Public URL where the frontend is accessible (used for CORS, redirects)
FRONTEND_URL=https://your-domain.com

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL: trace | debug | info | warn | error
LOG_LEVEL=info

# ── NOT needed on VPS (Replit-specific) ──────────────────────────────────────
# REPL_IDENTITY — Replit auth token (auto-set by Replit)
# REPLIT_BASE_PATH — path prefix in Replit proxy
# REPLIT_DEV_DOMAIN — Replit dev domain
# REPLIT_DOMAINS — Replit domain list
# REPLIT_CONNECTORS_HOSTNAME — Replit internal
# DEFAULT_OBJECT_STORAGE_BUCKET_ID — Replit Object Storage bucket
